#!/bin/bash # shebang, specifica quale interprete sarà utilizzato per eseguire lo script (in questo caso bash)
# Naked variables

echo

# When is a variable "naked", i.e., lacking the '$' in front?
# When it is being assigned, rather than referenced.

# Assignment
a=879 # assegna alla variabile a il valore 879
echo "The value of \"a\" is $a." # stampa "The value of "a" è 879"

# Assignment using 'let'
let a=16+5 # permette di calcolare la somma, il valore di a ora sarà 21 
echo "The value of \"a\" is now $a."  # stampa "The value of "a" è ora 21"

echo

# In a 'for' loop (really, a type of disguised assignment):
echo -n "Values of \"a\" in the loop are: " 
for a in 7 8 9 11
do
  echo -n "$a "
done # questo ciclo for stampa sulla stessa riga (grazie all'opzione -n) "The values of "a" in the loop are: 7 8 9 11"

echo
echo

# In a 'read' statement (also a type of assignment):
echo -n "Enter \"a\" "  # stampa "Enter "a" "
read a                  # legge input da tastiera e lo assegna alla variabile a
echo "The value of \"a\" is now $a." # "The value of "a" is now valore_inserito"

echo

exit 0 # termina lo script (eseguito con successo 0)

